generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Volunteer {
  id          Int     @default(autoincrement())
  email       String  @id
  username    String
  phoneNo     String
  password    String
  availability String @default("no") // "yes" or "no"
  
  assignments Assignment[] 
}

model Admin {
  id       Int    @default(autoincrement())
  email    String @id
  username String
  phoneNo  String
  password String
}

model Assignment {
  id           Int      @id @default(autoincrement())
  task         String
  status       String   @default("assigned")
  createdAt    DateTime @default(now())

  volunteerEmail String
  volunteer    Volunteer @relation(fields: [volunteerEmail], references: [email])
}

model Event {
  id              Int      @id @default(autoincrement())
  title           String
  text            String

  isEvent         Boolean  @default(false)
  eventDate       String?

  isEmergency     Boolean  @default(false)
  isRescue        Boolean  @default(false)

  rescueLocation  String?
  rescueAnimal    String?
  rescuePeople    String?

  image           String?  // base64 or URL

  createdAt       DateTime @default(now())
}

model Donation {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  amount    Float     
  feedback  String?
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}